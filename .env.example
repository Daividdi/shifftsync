# ============================================================
#  ShiftSync — Environment Variables
#  Copie este arquivo para .env e preencha os valores reais
# ============================================================

# -- Servidor --
NODE_ENV=production
PORT=3001

# -- JWT --
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria
JWT_EXPIRES_IN=8h

# -- LDAP --
LDAP_URL=ldap://seu-servidor-ldap:389
LDAP_BIND_DN=cn=admin,dc=empresa,dc=com
LDAP_BIND_PASSWORD=senha_do_bind
LDAP_BASE_DN=ou=users,dc=empresa,dc=com
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_FULLNAME_ATTR=displayName
LDAP_EMAIL_ATTR=mail
LDAP_DEPT_ATTR=department
LDAP_TITLE_ATTR=title
# Para Active Directory use: objectClass=user
# Para OpenLDAP use:         objectClass=inetOrgPerson
LDAP_FILTER=(objectClass=user)

# -- Banco de Dados (SQLite — caminho dentro do container) --
DB_PATH=/app/data/shiftsync.db

# -- CORS --
CORS_ORIGIN=http://localhost
